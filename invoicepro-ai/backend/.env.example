# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/invoicepro

# Session secret (use a long random string in production)
SESSION_SECRET=change_this_to_a_long_random_secret

# Server port
PORT=5000

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost:5000

# Groq AI API Keys — get yours free at https://console.groq.com
GROQ_PRIMARY_KEY=your_groq_primary_key_here
GROQ_FALLBACK_KEY_1=your_groq_fallback_key_1_here
GROQ_FALLBACK_KEY_2=your_groq_fallback_key_2_here

# Groq model to use
GROQ_MODEL=openai/gpt-oss-20b
